# EmailJS configuration
# Sign up at https://www.emailjs.com/ and create a service + template to get these values.
# Copy this file to .env and fill in your real values. Do NOT commit .env to version control.

VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
